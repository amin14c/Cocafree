<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".RecoveryApplication"
        android:allowBackup="false"
        android:icon="@drawable/ic_recovery_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_recovery_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.RecoveryPath">

        <activity android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.patient.PatientSelectActivity"
            android:exported="false" />
        <activity android:name=".ui.patient.PatientDashboardActivity"
            android:exported="false" />
        <activity android:name=".ui.patient.DailyCheckInActivity"
            android:exported="false" />
        <activity android:name=".ui.patient.CravingLogActivity"
            android:exported="false" />
        <activity android:name=".ui.patient.ToolsActivity"
            android:exported="false" />
        <activity android:name=".ui.doctor.DoctorDashboardActivity"
            android:exported="false" />
        <activity android:name=".ui.doctor.PatientDetailActivity"
            android:exported="false" />
        <activity android:name=".ui.doctor.AddPatientActivity"
            android:exported="false" />
    </application>

</manifest>
